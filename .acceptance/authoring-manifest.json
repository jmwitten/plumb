{
  "authoring_grammar": {
    "certification_contract": {
      "filename": "{slug}.cert.yaml",
      "minimal": {
        "schema_version": 1,
        "subject": {
          "kind": "standalone_detail",
          "source": "{slug}.spec.yaml"
        }
      }
    },
    "component": {
      "optional": [
        "name",
        "reader_name",
        "params",
        "place",
        "features",
        "was"
      ],
      "params": "mapping passed to the selected registered component",
      "required": [
        "id",
        "type"
      ]
    },
    "component_conventions": {
      "lumber": {
        "end": [
          "near",
          "far"
        ],
        "end_cut_required": [
          "end",
          "miter_angle_degrees",
          "long_face"
        ],
        "end_cuts": "list of end-cut mappings",
        "length_semantics": "long_point_to_long_point",
        "long_face": [
          "top",
          "bottom"
        ],
        "miter_angle_degrees": "degrees off square",
        "rule": "Any end_cuts require length_semantics to be authored as long_point_to_long_point. For equal symmetric planar miters, derive the conventional off-square angle from the included corner angle before authoring the cuts.",
        "symmetric_planar_miter": "off_square_degrees = 90 - included_corner_degrees / 2"
      }
    },
    "connection": {
      "hardware": "ordered list of declared component ids",
      "optional": [
        "hardware",
        "params",
        "surfaces",
        "assumptions",
        "label",
        "expect",
        "install",
        "process"
      ],
      "params": "mapping passed to the selected registered connection type",
      "required": [
        "type",
        "parts"
      ]
    },
    "detail_spec": {
      "optional": [
        "callouts",
        "connections",
        "cross_check",
        "derived",
        "design_review",
        "doc",
        "explode",
        "export",
        "foundations",
        "params",
        "retire",
        "roles",
        "sequence",
        "spatial",
        "type",
        "units",
        "validation"
      ],
      "required": [
        "name",
        "components"
      ]
    },
    "placement": {
      "exactly_one": {
        "mate": {
          "example": {
            "datum": "cut_near",
            "flip": true,
            "to": "previous_member",
            "to_datum": "cut_far"
          },
          "optional": [
            "to_datum",
            "offset",
            "rotate",
            "flip"
          ],
          "physical_cut_face_rule": "For cut_near/cut_far mates, use flip: true so face normals oppose. If an omitted or false flip produces interference, scaffold reports the exact corrected --place assignment.",
          "required": [
            "datum",
            "to"
          ],
          "shape_note": "Use these keys directly in the placement mapping; do not wrap them in a nested mate key."
        },
        "mount": {
          "optional": [
            "center",
            "ground",
            "mirror"
          ],
          "required": [
            "to",
            "face",
            "axis"
          ],
          "standoff_exactly_one": [
            "flush",
            "clear_by",
            "offset"
          ]
        },
        "raw": {
          "example": {
            "raw": {
              "at": [
                0,
                0,
                0
              ]
            }
          },
          "optional": [
            "rotate"
          ],
          "required": [
            "at"
          ],
          "shape": {
            "at": "[x, y, z]",
            "rotate": "[[axis, degrees], ...]"
          },
          "shape_note": "The raw wrapper is required; author raw fields inside a single raw mapping.",
          "wrapper": "raw"
        }
      },
      "form_selection": "Choose exactly one form below. Mate fields are authored directly in the placement mapping; raw and mount fields require their named YAML wrappers.",
      "omitted": "Identity placement at the origin; valid syntax, but multiple members may remain physically unresolved."
    },
    "scaffold_command": {
      "argv": [
        "python",
        "-m",
        "detailgen.authoring",
        "scaffold",
        "--slug",
        "{slug}",
        "--out",
        "details"
      ],
      "example": [
        "python",
        "-m",
        "detailgen.authoring",
        "scaffold",
        "--slug",
        "example_detail",
        "--out",
        "details",
        "--component",
        "base:slab",
        "--set",
        "base.width=12 in",
        "--set",
        "base.length=18 in",
        "--place",
        "base={raw: {at: [0, 0, 0]}}"
      ],
      "grammar_argv": [
        "python",
        "-m",
        "detailgen.authoring",
        "grammar"
      ],
      "length_values": {
        "bare_numbers": "millimeters",
        "generated_document_units": "mm",
        "other_units": "use a unit-suffixed YAML string, such as '42 in'"
      },
      "policy": "Values and placements are explicit; the scaffolder fails closed instead of inferring geometry. Bare numeric component and placement lengths are millimeters.",
      "repeatable": {
        "--component": "ID:REGISTERED_TYPE",
        "--connection": "REGISTERED_TYPE:PART_ID[,PART_ID...]",
        "--connection-hardware": "ZERO_BASED_INDEX=PART_ID[,PART_ID...]",
        "--connection-set": "ZERO_BASED_INDEX.PARAM=YAML_VALUE",
        "--place": "ID=YAML_MAPPING. Mate fields are direct (no mate wrapper), for example ID={datum: LOCAL_DATUM, to: TARGET_ID, to_datum: TARGET_DATUM, flip: true}. The raw wrapper is required for raw transforms, for example ID={raw: {at: [0, 0, 0]}}.",
        "--set": "ID.PARAM=YAML_VALUE"
      }
    },
    "schema": "detailgen/authoring-grammar/v1",
    "validation": {
      "dimensions": {
        "intrinsic_length_guidance": "No intrinsic member-length measure exists: do not use xlen for a rotated member; omit the claim or extend the platform.",
        "measures": [
          "xmin",
          "xmax",
          "xmid",
          "xlen",
          "ymin",
          "ymax",
          "ymid",
          "ylen",
          "zmin",
          "zmax",
          "zmid",
          "zlen"
        ],
        "optional": [
          "tolerance",
          "negate",
          "op",
          "minus_part",
          "minus_measure"
        ],
        "required": [
          "name",
          "part",
          "measure",
          "expected"
        ],
        "rotation_invariant_member_length": null,
        "semantics": "Every measure is taken from the placed solid's world-axis bounding box; xlen/ylen/zlen are world-axis projections."
      }
    }
  },
